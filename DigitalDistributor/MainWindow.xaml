<Window x:Class="DigitalDistributor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Digital Distributor v1.0" 
        Height="650" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Background="#1A252F" Height="40" Padding="15,0">
            <TextBlock Text="DigitalDistributor: Робоча область" 
                       Foreground="#BDC3C7" 
                       VerticalAlignment="Center" 
                       FontWeight="SemiBold"/>
        </Border>

        <StackPanel DockPanel.Dock="Left" Width="220" Background="#2C3E50">
            <TextBlock Text="Меню" Foreground="White" FontSize="22" FontWeight="Bold" Margin="20,20,20,30"/>

            <Button Content="Каталог контенту" Height="45" Margin="10,5" Padding="10,0" HorizontalContentAlignment="Left" Click="BtnCatalog_Click"/>
            <Button Content="Моя бібліотека" Height="45" Margin="10,5" Padding="10,0" HorizontalContentAlignment="Left" Click="BtnLibrary_Click"/>
            <Button Content="Панель Адміна" Height="45" Margin="10,5" Padding="10,0" HorizontalContentAlignment="Left" Click="BtnAdmin_Click"/>

            <Separator Margin="15,30" Background="#34495E"/>
            <Button Content="Вихід" Height="45" Margin="10,5" Background="#E74C3C" Foreground="White" Click="BtnExit_Click"/>
        </StackPanel>

        <Border Background="#F5F6FA" Padding="20">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>

    </DockPanel>
</Window>
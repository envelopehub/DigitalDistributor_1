<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="PrimaryColor"       Color="#4DA6FF"/>
    <SolidColorBrush x:Key="PrimaryDarkColor"   Color="#2E8AE6"/>
    <SolidColorBrush x:Key="PrimaryLightColor"  Color="#1A2D4A"/>
    <SolidColorBrush x:Key="SecondaryColor"     Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SidebarBg"          Color="#0D1117"/>
    <SolidColorBrush x:Key="SidebarHover"       Color="#1C2333"/>
    <SolidColorBrush x:Key="SidebarActive"      Color="#2563EB"/>
    <SolidColorBrush x:Key="BackgroundColor"    Color="#161B27"/>
    <SolidColorBrush x:Key="CardBackground"     Color="#1C2333"/>
    <SolidColorBrush x:Key="TextColor"          Color="#E2E8F0"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="#8B9BB4"/>
    <SolidColorBrush x:Key="DangerColor"        Color="#FC6D71"/>
    <SolidColorBrush x:Key="SuccessColor"       Color="#48BB78"/>
    <SolidColorBrush x:Key="WarningColor"       Color="#F6AD55"/>
    <SolidColorBrush x:Key="BorderColor"        Color="#2D3748"/>
    <SolidColorBrush x:Key="InputBackground"    Color="#242E42"/>
    <SolidColorBrush x:Key="PageHeaderBg"       Color="#1C2333"/>

    <sys:String x:Key="ThemeName">Темна</sys:String>

</ResourceDictionary>

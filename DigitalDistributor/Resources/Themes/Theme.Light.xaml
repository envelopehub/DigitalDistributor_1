<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="PrimaryColor"       Color="#0078D4"/>
    <SolidColorBrush x:Key="PrimaryDarkColor"   Color="#005A9E"/>
    <SolidColorBrush x:Key="PrimaryLightColor"  Color="#E8F4FC"/>
    <SolidColorBrush x:Key="SecondaryColor"     Color="#1B1F2A"/>
    <SolidColorBrush x:Key="SidebarBg"          Color="#161B27"/>
    <SolidColorBrush x:Key="SidebarHover"       Color="#232A3B"/>
    <SolidColorBrush x:Key="SidebarActive"      Color="#0078D4"/>
    <SolidColorBrush x:Key="BackgroundColor"    Color="#F3F4F8"/>
    <SolidColorBrush x:Key="CardBackground"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextColor"          Color="DarkGray"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="#6B7280"/>
    <SolidColorBrush x:Key="DangerColor"        Color="#E53E3E"/>
    <SolidColorBrush x:Key="SuccessColor"       Color="#38A169"/>
    <SolidColorBrush x:Key="WarningColor"       Color="#D69E2E"/>
    <SolidColorBrush x:Key="BorderColor"        Color="#E2E8F0"/>
    <SolidColorBrush x:Key="InputBackground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PageHeaderBg"       Color="#FFFFFF"/>

    <sys:String x:Key="ThemeName">Світла</sys:String>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="PrimaryColor"       Color="#9B59B6"/>
    <SolidColorBrush x:Key="PrimaryDarkColor"   Color="#7D3C98"/>
    <SolidColorBrush x:Key="PrimaryLightColor"  Color="#F3E8FF"/>
    <SolidColorBrush x:Key="SecondaryColor"     Color="#2D1B3D"/>
    <SolidColorBrush x:Key="SidebarBg"          Color="#1A0D2E"/>
    <SolidColorBrush x:Key="SidebarHover"       Color="#2D1B4E"/>
    <SolidColorBrush x:Key="SidebarActive"      Color="#9B59B6"/>
    <SolidColorBrush x:Key="BackgroundColor"    Color="#F5F0FF"/>
    <SolidColorBrush x:Key="CardBackground"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextColor"          Color="DarkMagenta"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="#6B5B8A"/>
    <SolidColorBrush x:Key="DangerColor"        Color="#E53E3E"/>
    <SolidColorBrush x:Key="SuccessColor"       Color="#38A169"/>
    <SolidColorBrush x:Key="WarningColor"       Color="#D69E2E"/>
    <SolidColorBrush x:Key="BorderColor"        Color="#DDD0F0"/>
    <SolidColorBrush x:Key="InputBackground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PageHeaderBg"       Color="#FFFFFF"/>

    <sys:String x:Key="ThemeName">Фіолетова</sys:String>

</ResourceDictionary>

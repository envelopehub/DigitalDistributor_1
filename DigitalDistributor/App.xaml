<Application x:Class="DigitalDistributor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/AuthWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Індекс 0: активна тема (замінюється при перемиканні) -->
                <ResourceDictionary Source="Resources/Themes/Theme.Purple.xaml"/>
                <!-- Індекс 1: стилі елементів керування -->
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <!-- Індекс 2: мовний файл (замінюється при перемиканні) -->
                <ResourceDictionary Source="Resources/Lang.uk-UA.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
<Page x:Class="DigitalDistributor.Views.ContentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі контенту">

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопка назад -->
        <Border Grid.Row="0" Background="White" Padding="20,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Button Content="{DynamicResource m_BackToCatalog}"
                    HorizontalAlignment="Left" Height="36" Padding="14,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnBack_Click"/>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Банер -->
                <Border Grid.Column="0" Height="300" CornerRadius="12"
                        Background="{Binding ImageColor}">
                    <TextBlock Text="{Binding TypeIcon}"
                               FontSize="90" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White"/>
                </Border>

                <!-- Інформація -->
                <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Top">
                    <TextBlock x:Name="TxtType" FontSize="12" FontWeight="SemiBold"
                               Foreground="#0078D4" Margin="0,0,0,8"/>

                    <TextBlock x:Name="TxtTitle" FontSize="30" FontWeight="Bold"
                               Foreground="#1B1F2A" TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="TxtGenre" FontSize="14" Foreground="#6B7280"
                               Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtDescription" FontSize="14" Foreground="#4A5568"
                               TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,30"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <TextBlock x:Name="TxtPrice" FontSize="34" FontWeight="Bold"
                                   Foreground="#0078D4"/>
                    </StackPanel>

                    <Button x:Name="BtnBuy" Content="{DynamicResource m_Buy}"
                            Width="200" Height="46" HorizontalAlignment="Left"
                            Style="{StaticResource SuccessButton}"
                            Click="BtnBuy_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

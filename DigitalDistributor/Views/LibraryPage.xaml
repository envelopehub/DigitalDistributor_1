<Page x:Class="DigitalDistributor.Views.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Моя бібліотека">

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" Padding="24,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{DynamicResource m_MyLibrary}"
                           Style="{StaticResource HeaderText}" Margin="0"/>
                <TextBlock x:Name="TxtCount" Foreground="#6B7280" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Список або повідомлення про порожню бібліотеку -->
        <Grid Grid.Row="1">

            <!-- Порожня бібліотека -->
            <StackPanel x:Name="PanelEmpty" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="📚" FontSize="64" HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Ваша бібліотека порожня" FontSize="18" FontWeight="SemiBold"
                           Foreground="#4A5568" HorizontalAlignment="Center"/>
                <TextBlock Text="Придбайте контент у Каталозі, щоб він з'явився тут."
                           FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Список придбаного -->
            <ScrollViewer x:Name="ScrollLib" VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed" Padding="24,16,24,24">
                <ItemsControl x:Name="LibraryItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210" Height="270" CornerRadius="10"
                                    Margin="0,0,16,16" Background="White">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.07"
                                                      BlurRadius="12" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="10,10,0,0"
                                            Background="{Binding ImageColor}">
                                        <TextBlock Text="{Binding TypeIcon}"
                                                   FontSize="40" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="White"/>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="14,10,14,10">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   TextWrapping="Wrap" MaxHeight="42"
                                                   Foreground="#1A1A2E"/>
                                        <TextBlock Text="{Binding Genre}"
                                                   Foreground="#6B7280" FontSize="11"
                                                   Margin="0,3,0,0"/>
                                        <Border Background="#E8F4FC" CornerRadius="4"
                                                Padding="6,2" Margin="0,8,0,0"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="✓ Придбано" Foreground="#0078D4"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

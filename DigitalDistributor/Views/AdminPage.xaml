<Page x:Class="DigitalDistributor.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Адмін-панель">

    <Grid Background="{DynamicResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource PageHeaderBg}" Padding="24,20"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <TextBlock Text="{DynamicResource m_AdminPanel}"
                       Style="{StaticResource HeaderText}" Margin="0"/>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1">

            <!-- ======= ВКЛАДКА КОНТЕНТ ======= -->
            <TabItem Header="{DynamicResource m_TabContent}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Таблиця -->
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                        <DataGrid x:Name="ContentDataGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionChanged="ContentGrid_SelectionChanged"
                                  CanUserResizeRows="False" SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource m_ColTitle}"  Binding="{Binding Title}"  Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource m_ColGenre}"  Binding="{Binding Genre}"  Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource m_ColPrice}"  Binding="{Binding Price}"  Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource m_ColType}"   Binding="{Binding Type}"   Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Форма у ScrollViewer щоб прокручувалась -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            Margin="16,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource m_FormTitle}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryColor}"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="{DynamicResource m_FieldTitle}"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TxtTitle"/>

                                <TextBlock Text="{DynamicResource m_FieldGenre}"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TxtGenre"/>

                                <TextBlock Text="{DynamicResource m_FieldDesc}"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TxtDesc" Height="70"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>

                                <TextBlock Text="{DynamicResource m_FieldPrice}"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TxtPrice"
                                         ToolTip="Наприклад: 299.99"/>

                                <TextBlock Text="{DynamicResource m_FieldType}"
                                           Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="CmbType">
                                    <ComboBoxItem Content="{DynamicResource m_TypeGame_cb}"/>
                                    <ComboBoxItem Content="{DynamicResource m_TypeMovie_cb}"/>
                                    <ComboBoxItem Content="{DynamicResource m_TypeSoftware_cb}"/>
                                </ComboBox>

                                <!-- Помилка валідації -->
                                <TextBlock x:Name="TxtError"
                                           Foreground="{DynamicResource DangerColor}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Margin="0,0,0,10" Visibility="Collapsed"/>

                                <Button Content="{DynamicResource m_BtnSave}"
                                        Click="BtnSave_Click" Height="40" Margin="0,4,0,8"/>
                                <Button Content="{DynamicResource m_BtnClear}"
                                        Click="BtnClear_Click" Height="40" Margin="0,0,0,8"
                                        Style="{StaticResource SecondaryButton}"/>
                                <Button Content="{DynamicResource m_BtnDelete}"
                                        Click="BtnDelete_Click" Height="40"
                                        Style="{StaticResource DangerButton}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ======= ВКЛАДКА КОРИСТУВАЧІ ======= -->
            <TabItem Header="{DynamicResource m_TabUsers}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="{DynamicResource m_BtnRefresh}"
                                Click="BtnRefreshUsers_Click"
                                Height="36" Width="180" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtUserCount"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="{DynamicResource CardBackground}"
                            CornerRadius="8" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1">
                        <DataGrid x:Name="UsersDataGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserResizeRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource m_ColLogin}"
                                                    Binding="{Binding Login}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource m_ColRole}"
                                                    Binding="{Binding Role}" Width="130"/>
                                <DataGridTextColumn Header="{DynamicResource m_ColDate}"
                                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                    Width="170"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
<Page x:Class="DigitalDistributor.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель Адміністратора">

    <Grid Background="White" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="База контенту" Margin="0,0,20,0" FontSize="16" FontWeight="SemiBold">
            <DataGrid x:Name="ContentDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionChanged="ContentDataGrid_SelectionChanged" Background="White" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="100"/>
                    <DataGridTextColumn Header="Ціна (₴)" Binding="{Binding Price}" Width="80"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Керування записом" FontSize="16" FontWeight="SemiBold">
            <StackPanel Margin="15">

                <TextBlock Text="Назва контенту:"/>
                <TextBox x:Name="TxtTitle"/>

                <TextBlock Text="Жанр:"/>
                <TextBox x:Name="TxtGenre"/>

                <TextBlock Text="Ціна:"/>
                <TextBox x:Name="TxtPrice" ToolTip="Введіть число більше за 0"/>

                <TextBlock Text="Тип контенту:"/>
                <ComboBox x:Name="CmbType" Margin="0,5,0,15" Padding="5">
                    <ComboBoxItem Content="Гра (Game)"/>
                    <ComboBoxItem Content="Фільм (Movie)"/>
                    <ComboBoxItem Content="Програма (Software)"/>
                </ComboBox>

                <TextBlock x:Name="TxtError" Foreground="{StaticResource DangerColor}" TextWrapping="Wrap" Margin="0,0,0,15" Visibility="Collapsed"/>

                <Button Content="Зберегти / Додати" Click="BtnSave_Click" Margin="0,0,0,10"/>
                <Button Content="Очистити форму" Click="BtnClear_Click" Margin="0,0,0,10" Background="Gray"/>
                <Button Content="Видалити вибране" Click="BtnDelete_Click" Background="{StaticResource DangerColor}"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Page>
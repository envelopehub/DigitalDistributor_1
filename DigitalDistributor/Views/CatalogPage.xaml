<Page x:Class="DigitalDistributor.Views.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CatalogPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Популярний контент" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <WrapPanel HorizontalAlignment="Left">

                <Border Width="220" Height="280" Background="White" CornerRadius="10" Margin="0,0,20,20" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Height="130" Background="#BDC3C7" CornerRadius="5" Margin="0,0,0,15"/>
                        <TextBlock Text="The Witcher 3" FontWeight="Bold" FontSize="18" TextWrapping="Wrap"/>
                        <TextBlock Text="RPG / Відкритий світ" Foreground="Gray" FontSize="12" Margin="0,5,0,15"/>
                        <Button Content="Детальніше" Height="35" Click="BtnItem_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="220" Height="280" Background="White" CornerRadius="10" Margin="0,0,20,20" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Height="130" Background="#BDC3C7" CornerRadius="5" Margin="0,0,0,15"/>
                        <TextBlock Text="Cyberpunk 2077" FontWeight="Bold" FontSize="18" TextWrapping="Wrap"/>
                        <TextBlock Text="Action / Кіберпанк" Foreground="Gray" FontSize="12" Margin="0,5,0,15"/>
                        <Button Content="Детальніше" Height="35" Click="BtnItem_Click"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
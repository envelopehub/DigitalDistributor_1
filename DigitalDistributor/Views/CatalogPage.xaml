<Page x:Class="DigitalDistributor.Views.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог">

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" Padding="24,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{DynamicResource m_ContentCatalog}"
                               Style="{StaticResource HeaderText}" Margin="0"/>
                    <TextBlock x:Name="TxtCount" Foreground="#6B7280" FontSize="12"/>
                </StackPanel>

                <!-- Поле пошуку -->
                <TextBox Grid.Column="1" x:Name="TxtSearch"
                         Width="240" Height="36" VerticalAlignment="Center"
                         Text="" Margin="0"
                         TextChanged="TxtSearch_TextChanged"/>
            </Grid>
        </Border>

        <!-- Фільтри -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,14,24,0">
            <Button x:Name="BtnAll"      Content="{DynamicResource m_FilterAll}"      Click="BtnFilter_Click" Margin="0,0,8,0" Tag="All"      Style="{StaticResource SidebarButtonActive}"/>
            <Button x:Name="BtnGames"    Content="{DynamicResource m_FilterGame}"     Click="BtnFilter_Click" Margin="0,0,8,0" Tag="Game"     Style="{StaticResource SidebarButton}"/>
            <Button x:Name="BtnMovies"   Content="{DynamicResource m_FilterMovie}"    Click="BtnFilter_Click" Margin="0,0,8,0" Tag="Movie"    Style="{StaticResource SidebarButton}"/>
            <Button x:Name="BtnSoftware" Content="{DynamicResource m_FilterSoftware}" Click="BtnFilter_Click" Tag="Software"                  Style="{StaticResource SidebarButton}"/>
        </StackPanel>

        <!-- Список карток -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
            <ItemsControl x:Name="ContentItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Картка одного елемента -->
                        <Border Width="210" Height="290" CornerRadius="10" Margin="0,0,16,16"
                                Background="White" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="14" ShadowDepth="2"/>
                            </Border.Effect>

                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                To="0.18" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                To="0.07" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="130"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Кольоровий банер замість фото -->
                                <Border Grid.Row="0" CornerRadius="10,10,0,0"
                                        Background="{Binding ImageColor}">
                                    <TextBlock Text="{Binding TypeIcon}"
                                               FontSize="44" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="White"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="14,10,14,10">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold" FontSize="14"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               Foreground="#1A1A2E"/>
                                    <TextBlock Text="{Binding Genre}"
                                               Foreground="#6B7280" FontSize="11"
                                               Margin="0,3,0,6"/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}"
                                               FontWeight="Bold" FontSize="15"
                                               Foreground="#0078D4" Margin="0,0,0,8"/>
                                    <Button Content="{DynamicResource m_Details}"
                                            Height="30" FontSize="12" Padding="0"
                                            Click="BtnDetails_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
<Window x:Class="DigitalDistributor.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Digital Distributor" Height="560" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Ліва панель — брендинг -->
        <Border Grid.Column="0" Background="#161B27">
            <StackPanel VerticalAlignment="Center" Margin="40,0">
                <TextBlock Text="🎮" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16" VerticalAlignment="Top"/>
                <TextBlock Text="Digital" FontSize="28" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Distributor" FontSize="28" FontWeight="Bold" Foreground="#0078D4"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Ваш особистий магазин цифрового контенту. Ігри, фільми, програми — все в одному місці."
                           Foreground="#8896A8" TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="13" LineHeight="20"/>
            </StackPanel>
        </Border>

        <!-- Права панель — форма -->
        <Grid Grid.Column="1" Background="White">

            <!-- Вибір мови у правому верхньому куті -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Margin="0,16,20,0">
                <TextBlock Text="🌐" FontSize="14" Foreground="#6B7280" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbLanguage" Width="120" SelectionChanged="CmbLanguage_SelectionChanged"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="Українська" Tag="uk-UA" IsSelected="True"/>
                    <ComboBoxItem Content="English"    Tag="en-US"/>
                </ComboBox>
            </StackPanel>

            <!-- Панель входу -->
            <StackPanel x:Name="PanelLogin" VerticalAlignment="Center" Margin="50,0">
                <TextBlock Text="{DynamicResource m_LoginTitle}"
                           FontSize="26" FontWeight="Bold" Foreground="#1B1F2A"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource m_LoginSubtitle}"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock Text="{DynamicResource m_Login}" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtLoginLogin"/>

                <TextBlock Text="{DynamicResource m_Password}" Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="TxtLoginPassword"/>

                <TextBlock x:Name="TxtLoginError" Foreground="#E53E3E"
                           FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <Button Content="{DynamicResource m_BtnLogin}"
                        Click="BtnLogin_Click" Height="42" Margin="0,4,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource m_NoAccount}"
                               Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource m_BtnRegister}"
                            Click="BtnShowRegister_Click"
                            Background="Transparent" Foreground="#0078D4"
                            FontSize="12" FontWeight="SemiBold" Padding="6,0"
                            BorderThickness="0"/>
                </StackPanel>
            </StackPanel>

            <!-- Панель реєстрації -->
            <StackPanel x:Name="PanelRegister" VerticalAlignment="Center"
                        Margin="50,0" Visibility="Collapsed">
                <TextBlock Text="{DynamicResource m_BtnRegister}"
                           FontSize="26" FontWeight="Bold" Foreground="#1B1F2A"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource m_RegisterSubtitle}"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="{DynamicResource m_Login}" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtRegLogin"/>

                <TextBlock Text="{DynamicResource m_Password}" Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="TxtRegPassword"/>

                <!-- Вибір ролі при реєстрації -->
                <TextBlock Text="{DynamicResource m_Role}" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="CmbRole" Margin="0,4,0,12">
                    <ComboBoxItem Content="Користувач" Tag="User" IsSelected="True"/>
                    <ComboBoxItem Content="Адміністратор" Tag="Admin"/>
                </ComboBox>

                <TextBlock x:Name="TxtRegError" Foreground="#E53E3E"
                           FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <Button Content="{DynamicResource m_BtnRegister}"
                        Click="BtnRegister_Click" Height="42" Margin="0,4,0,16"
                        Style="{StaticResource SuccessButton}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource m_HasAccount}"
                               Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource m_BtnLogin}"
                            Click="BtnShowLogin_Click"
                            Background="Transparent" Foreground="#0078D4"
                            FontSize="12" FontWeight="SemiBold" Padding="6,0"
                            BorderThickness="0"/>
                </StackPanel>
            </StackPanel>

        </Grid>
    </Grid>
</Window>